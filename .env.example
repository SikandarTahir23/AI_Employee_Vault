# ==========================================
# SIKANDAR TAHIR | AI AGENCY DASHBOARD
# Meta (Facebook & Instagram) API Credentials
# ==========================================
# Get these from: https://developers.facebook.com/apps
# ==========================================

# Meta Access Token (Long-lived Page Access Token)
# Generate at: https://developers.facebook.com/tools/explorer
META_ACCESS_TOKEN=your_meta_access_token_here

# Facebook Page ID (The page you want to post to)
# Find it at: https://findmyfbid.in/ or in your Page settings
FB_PAGE_ID=your_facebook_page_id_here

# Instagram Business Account ID
# Find it via Graph API: GET /me/accounts?fields=instagram_business_account
IG_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id_here

# ==========================================
# Optional: For advanced features
# ==========================================
# Meta App ID (from your Facebook App Dashboard)
META_APP_ID=your_meta_app_id_here

# Meta App Secret (from your Facebook App Dashboard)
META_APP_SECRET=your_meta_app_secret_here

# ==========================================
# Existing Credentials (if any)
# ==========================================
# LinkedIn Client ID
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here

# LinkedIn Client Secret
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here

# Odoo Credentials
ODOO_URL=https://your-company.odoo.com
ODOO_DB=your_database_name
ODOO_API_KEY=your_odoo_api_key_here
