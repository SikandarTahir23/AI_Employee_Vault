# ===========================================
# AI Employee Vault - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control!
# ===========================================

# -------------------------------------------
# Facebook Page Integration
# -------------------------------------------
# Get from: https://developers.facebook.com/tools/explorer/
# META_ACCESS_TOKEN=
# FB_PAGE_ID=

# App credentials (for token debugging)
# Get from: https://developers.facebook.com/apps/
# META_APP_ID=
# META_APP_SECRET=

# -------------------------------------------
# Gmail Integration
# -------------------------------------------
# Get from: https://console.cloud.google.com/apis/credentials
# Download as credentials.json and place in project root
# (Not stored here - see credentials.json)

# -------------------------------------------
# WhatsApp Integration
# -------------------------------------------
# No credentials needed - uses browser session
# Session stored in .whatsapp_session/ directory

# -------------------------------------------
# Other Integrations
# -------------------------------------------
# Add other API keys and tokens below
